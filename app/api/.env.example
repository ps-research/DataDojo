# Copy to .env and fill in. Never commit .env.
NODE_ENV=production
PORT=4000
CLIENT_ORIGIN=https://datadojo.duckdns.org

MONGO_URI=mongodb://127.0.0.1:27017/datadojo
REDIS_URL=redis://127.0.0.1:6379

# generate with: openssl rand -hex 32
JWT_SECRET=
JWT_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# Judge engine endpoints
PG_URL=postgresql://postgres:postgres@127.0.0.1:5432/datadojo_judge
MYSQL_SOCKET=/run/mysqld/mysqld.sock
MYSQL_USER=root
MYSQL_DB=datadojo_judge
MSSQL_HOST=127.0.0.1
MSSQL_PORT=1433
MSSQL_USER=SA
MSSQL_PASSWORD=DataDojo!2026
MSSQL_DB=datadojo_judge
PYTHON_BIN=python3
R_BIN=Rscript

JUDGE_TIMEOUT_MS=5000

# AI hints (Google Gemini/Gemma). Comma-separated keys are rotated on quota.
# Leave empty to disable the AI Coach (feature degrades gracefully).
GEMINI_API_KEYS=
GEMINI_MODEL=gemma-4-31b-it
AI_HINTS_PER_HOUR=10
