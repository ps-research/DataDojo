{
  "name": "datadojo-api",
  "version": "1.0.0",
  "description": "DataDojo Online Judge — API and multi-engine judge (TypeScript)",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "seed:dev": "tsx src/scripts/seed-dev.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@duckdb/node-api": "1.5.4-r.1",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.3.0",
    "bullmq": "^5.12.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.7.0",
    "morgan": "^1.10.0",
    "mssql": "^11.0.1",
    "mysql2": "^3.11.0",
    "pg": "^8.13.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.11",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/mssql": "^12.3.0",
    "@types/node": "^22.5.0",
    "@types/pg": "^8.11.8",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4"
  }
}
